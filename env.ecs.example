# Huawei ECS Environment Variables
# Copy this file to .env.ecs and update the values

# Database Configuration
DATABASE_TYPE=postgresql
DATABASE_URL=postgresql://prompify_user:your-secure-password@postgres:5432/prompify
POSTGRES_PASSWORD=your-secure-password

# JWT Configuration
JWT_SECRET=your-super-secure-jwt-secret-key-change-this-in-production

# Application Configuration
NODE_ENV=production
APP_URL=https://your-domain.com
PORT=3000

# Redis Configuration
REDIS_URL=redis://redis:6379

# AI Provider API Keys (optional)
OPENAI_API_KEY=your-openai-key
ANTHROPIC_API_KEY=your-anthropic-key
GOOGLE_GENERATIVE_AI_API_KEY=your-google-key
GROQ_API_KEY=your-groq-key
HuggingFace_API_KEY=your-huggingface-key
OPEN_ROUTER_API_KEY=your-openrouter-key
XAI_API_KEY=your-xai-key
TOGETHER_API_KEY=your-together-key
TOGETHER_API_BASE_URL=https://api.together.xyz/v1
OLLAMA_API_BASE_URL=http://localhost:11434

# AWS Bedrock (if using)
AWS_BEDROCK_CONFIG={"region":"us-east-1","accessKeyId":"your-key","secretAccessKey":"your-secret"}

# Application Settings
VITE_LOG_LEVEL=info
DEFAULT_NUM_CTX=32768
AUTH_DISABLED=false

# Email Configuration (optional)
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Security
SESSION_SECRET=your-session-secret-key
COOKIE_SECRET=your-cookie-secret-key

# Monitoring (optional)
SENTRY_DSN=your-sentry-dsn
LOG_LEVEL=info

