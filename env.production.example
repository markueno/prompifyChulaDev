# Production Environment Variables
# Copy this file to .env.production and update the values

# Database Configuration
DATABASE_TYPE=postgresql
DATABASE_URL=postgresql://prompify_user:your-secure-password@postgres:5432/prompify

# PostgreSQL Database Password (change this!)
POSTGRES_PASSWORD=your-secure-password

# JWT Configuration
JWT_SECRET=your-super-secure-jwt-secret-key-change-this-in-production

# Application Configuration
NODE_ENV=production
APP_URL=https://your-domain.com

# Redis Configuration (optional)
REDIS_URL=redis://redis:6379

# Email Configuration (if using real email service)
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# AI Provider API Keys (optional)
OPENAI_API_KEY=your-openai-key
ANTHROPIC_API_KEY=your-anthropic-key
GOOGLE_API_KEY=your-google-key
COHERE_API_KEY=your-cohere-key

# Security
SESSION_SECRET=your-session-secret-key
COOKIE_SECRET=your-cookie-secret-key

# Authentication Bypass (DANGER: Only use for emergency access)
# Set to 'true' or '1' to temporarily disable authentication
# WARNING: This will allow anyone to access your application without login
 AUTH_DISABLED=false

# Monitoring (optional)
SENTRY_DSN=your-sentry-dsn
LOG_LEVEL=info 