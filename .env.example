# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  Prompify — environment variable reference                              ║
# ║  Copy this file:  cp .env.example .env                                  ║
# ║  Never commit the real .env — it contains secrets.                      ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── App ────────────────────────────────────────────────────────────────────────
NODE_ENV=production
APP_URL=https://www.prompify.com
PORT=5173

# ── Auth ───────────────────────────────────────────────────────────────────────
# Set to true ONLY for local dev / emergency access — never in production
AUTH_DISABLED=false

# Long random string — generate with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-long-random-string

# Require email verification on sign-up
EMAIL_VERIFICATION_REQUIRED=true

# ── Prompify PostgreSQL (main app database) ────────────────────────────────────
# This is the database Prompify itself uses (users, chats, sessions, etc.)
# It is NOT the per-app Supabase database below.
DATABASE_TYPE=postgresql
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/prompify

# Raw credentials (used by Docker Compose for the Prompify DB container)
POSTGRES_DB=prompify
POSTGRES_USER=prompify_user
POSTGRES_PASSWORD=change_me_strong_password

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Self-hosted Supabase  (per-app database — Base44-style)                    │
# │                                                                             │
# │  Each app a user builds in Prompify gets its own isolated schema in this    │
# │  Supabase instance.  The Admin Panel → Data section auto-connects using     │
# │  these credentials — users never see or enter them.                         │
# │                                                                             │
# │  Leave all three blank to disable platform-mode; the Data section will      │
# │  show a manual connect form so power users can bring their own Supabase.   │
# │                                                                             │
# │  How to get these values:                                                   │
# │    Cloud Supabase  → supabase.com → Project Settings → API                 │
# │    Self-hosted     → run generate-keys.js (see supabase/README) and copy   │
# │                       ANON_KEY / SERVICE_ROLE_KEY from supabase/.env        │
# └─────────────────────────────────────────────────────────────────────────────┘
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Email ──────────────────────────────────────────────────────────────────────
# Used for email verification, password reset, and chat invitations
SENDGRID_API_KEY=
FROM_EMAIL=noreply@yourdomain.com

# ── LLM / AI providers ─────────────────────────────────────────────────────────
# Set only the providers you want to use.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPEN_ROUTER_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
XAI_API_KEY=
PERPLEXITY_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=
DEEPSEEK_API_KEY=
HuggingFace_API_KEY=
TOGETHER_API_KEY=
TOGETHER_API_BASE_URL=
HYPERBOLIC_API_KEY=
HYPERBOLIC_API_BASE_URL=

# Alibaba Cloud DashScope / Qwen (OpenAI-compatible)
DASHSCOPE_API_KEY=
# International: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# China:         https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_BASE_URL=

# Local models
OLLAMA_API_BASE_URL=http://127.0.0.1:11434
LMSTUDIO_API_BASE_URL=
OPENAI_LIKE_API_BASE_URL=
OPENAI_LIKE_API_KEY=

# AWS Bedrock
# JSON: {"region":"us-east-1","accessKeyId":"...","secretAccessKey":"..."}
AWS_BEDROCK_CONFIG=

# ── GitHub ─────────────────────────────────────────────────────────────────────
# Used for git clone, push, and GitHub authentication inside generated apps
VITE_GITHUB_ACCESS_TOKEN=
VITE_GITHUB_TOKEN_TYPE=classic

# ── KooGallery (optional) ──────────────────────────────────────────────────────
KOOGALLERY_ACCESS_ID=
KOOGALLERY_ACCESS_KEY=
KOOGALLERY_API_BASE_URL=https://api.koogallery.com
KOOGALLERY_ENABLED=false

# ── UI feature flags ───────────────────────────────────────────────────────────
VITE_LOG_LEVEL=info
DISABLE_DYNAMIC_MODELS=false
VITE_HIDE_IMPORT_CHAT=false
VITE_HIDE_IMPORT_FOLDER=false
VITE_HIDE_GIT_CLONE=false
VITE_HIDE_SETTINGS=false
VITE_DISABLE_FRAMEWORK=false
VITE_DISABLE_LANGUAGE=false
VITE_DISABLE_CSS_FRAMEWORK=false
VITE_DISABLE_DATABASE=false

# Ollama context window size (optional — for large context models)
DEFAULT_NUM_CTX=
