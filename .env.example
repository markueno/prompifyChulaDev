# Copy this file to `.env` and fill in values (or rename: copy .env.example .env)
# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=5173
APP_URL=http://localhost:5173

# Set to true or 1 to skip login and use a mock admin (local/dev only — never in public prod)
AUTH_DISABLED=true
# Alternative name (same effect as AUTH_DISABLED):
# VITE_AUTH_DISABLED=true

# -----------------------------------------------------------------------------
# Database (when using PostgreSQL / app features that need DB)
# -----------------------------------------------------------------------------
DATABASE_TYPE=postgresql
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DBNAME

# Optional: Redis (if your deployment uses it)
# REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Auth (when AUTH_DISABLED is false)
# -----------------------------------------------------------------------------
JWT_SECRET=change-this-to-a-long-random-string

# -----------------------------------------------------------------------------
# Email (optional — verification / password reset)
# -----------------------------------------------------------------------------
# SENDGRID_API_KEY=
# FROM_EMAIL=noreply@example.com

# -----------------------------------------------------------------------------
# LLM / AI providers (set only what you use)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=
# OPEN_ROUTER_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# XAI_API_KEY=
# HuggingFace_API_KEY=
# TOGETHER_API_KEY=
# TOGETHER_API_BASE_URL=
# OLLAMA_API_BASE_URL=http://127.0.0.1:11434
# AWS_BEDROCK_CONFIG=

# Alibaba Cloud DashScope / Qwen (OpenAI-compatible; long API keys supported)
# DASHSCOPE_API_KEY=
# Intl default: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# China: https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_API_BASE_URL=

# -----------------------------------------------------------------------------
# Docker / dev tooling
# -----------------------------------------------------------------------------
# RUNNING_IN_DOCKER=true
# VITE_HMR_PROTOCOL=ws
# VITE_HMR_HOST=localhost
# VITE_HMR_PORT=5173
# CHOKIDAR_USEPOLLING=true
# WATCHPACK_POLLING=true

# -----------------------------------------------------------------------------
# App tuning
# -----------------------------------------------------------------------------
VITE_LOG_LEVEL=debug
DEFAULT_NUM_CTX=32768

# Optional UI flags (true / 1 to hide features)
# VITE_HIDE_IMPORT_CHAT=
# VITE_HIDE_IMPORT_FOLDER=
# VITE_HIDE_GIT_CLONE=
# VITE_HIDE_IMPORT_BUTTONS=
# VITE_HIDE_SETTINGS=
# VITE_DISABLE_PERSISTENCE=
# VITE_GITHUB_ACCESS_TOKEN=

# Koogallery (optional)
# KOOGALLERY_ACCESS_KEY=
# KOOGALLERY_API_BASE_URL=
# KOOGALLERY_ENABLED=true

# Server / git (optional)
# GITHUB_TOKEN=
